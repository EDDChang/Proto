# Credentials are NOT loaded from this file at runtime.
# This file documents the available config keys only.
#
# Preferred method: create ~/.protofiler/config.toml (outside the repo)
#
#   [ib]
#   host = "127.0.0.1"
#   port = 7497
#   client_id = 1
#
#   [sinopac]
#   api_key = "your_api_key"
#   secret_key = "your_secret_key"
#   ca_path = "/path/to/ca.pfx"
#   ca_passwd = "your_ca_password"
#   person_id = "A123456789"
#
# Alternative: set environment variables (higher priority than the config file)
#
#   IB_HOST / IB_PORT / IB_CLIENT_ID
#   SINOPAC_API_KEY / SINOPAC_SECRET_KEY / SINOPAC_CA_PATH / SINOPAC_CA_PASSWD / SINOPAC_PERSON_ID

# Interactive Brokers (TWS / IB Gateway)
IB_HOST=127.0.0.1
IB_PORT=7497          # 7497 = paper trading, 7496 = live
IB_CLIENT_ID=1

# Sinopac (永豐證券/期貨) — shioaji SDK
SINOPAC_API_KEY=your_api_key_here
SINOPAC_SECRET_KEY=your_secret_key_here
SINOPAC_CA_PATH=/path/to/your/ca.pfx   # required for futures orders
SINOPAC_CA_PASSWD=your_ca_password
SINOPAC_PERSON_ID=your_national_id
